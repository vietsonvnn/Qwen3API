# Alibaba Cloud Qwen3 TTS
QWEN_API_KEY=sk-your_api_key_here
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/api/v1

# Supabase (lấy từ supabase.com → Project Settings → API)
SUPABASE_URL=https://your_project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_KEY=your_service_role_key

# Server
PORT=3001

# CORS: set to your Cloudflare Pages URL in production
# Local dev:
CORS_ORIGIN=http://localhost:5173
# Production example:
# CORS_ORIGIN=https://qwen3api.pages.dev

# FFmpeg (leave empty — Railway installs it automatically via nixpacks.toml)
FFMPEG_PATH=
