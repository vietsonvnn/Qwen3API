# Supabase (lấy từ supabase.com → Project Settings → API)
VITE_SUPABASE_URL=https://your_project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Backend API URL
# Local dev: để trống (Vite proxy tự động chuyển /api → localhost:3001)
# Production: đặt là Railway backend URL
# VITE_API_URL=https://your-backend.railway.app
VITE_API_URL=
